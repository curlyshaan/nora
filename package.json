{
  "name": "nora",
  "version": "1.0.0",
  "description": "AI-powered investing learning assistant with Quatarly integration",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm install && npm run build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "keywords": [
    "ai",
    "investing",
    "quatarly",
    "claude"
  ],
  "author": "sshanoor",
  "license": "MIT",
  "dependencies": {
    "@simplewebauthn/server": "^9.0.0",
    "@tavily/core": "^0.7.2",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "finnhub": "^2.0.13",
    "nodemailer": "^8.0.4",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
